{
  "name": "ospex-benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shadow smoke harness for the Ospex sports-market decision benchmark",
  "license": "MIT",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "smoke": "tsx src/shadowSmoke.ts",
    "smoke:dry": "tsx src/shadowSmoke.ts --dry-run",
    "preflight": "tsx src/preflight.ts",
    "test": "tsx --test src/slateDate.test.ts src/bundle.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.7.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
