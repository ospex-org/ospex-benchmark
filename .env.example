# ---- Ospex public read path (live mode) ----
# Base URL of ospex-core-api. Defaults to the production API if unset.
OSPEX_API_URL=
# Supabase project URL + public anon key (read-only), used to read the
# current_odds reference-odds table. Both are required in live mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---- Provider credentials (live mode only; the dry run needs none) ----
# A missing key produces an explicit credential_missing result for that arm.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
