# ---- Ospex public read path (live mode) ----
# Base URL of ospex-core-api. Defaults to the production API if unset.
OSPEX_API_URL=
# Supabase project URL + public anon key (read-only), used for the public
# reference tables: current_odds (reference odds), closing_lines (scoring),
# and odds_history first-appearance reads (watch mode's late-detection gate).
# Both are required in live mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---- Provider credentials (preflight + live mode; the dry run needs none) ----
# A missing key produces an explicit credential_missing result for that arm.
# A local gitignored .env in the repo root is loaded automatically at startup;
# real environment variables always take precedence.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY is accepted as an alternative name for the Gemini key.
GEMINI_API_KEY=
XAI_API_KEY=
